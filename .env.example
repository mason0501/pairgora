# --- Database (Supabase Postgres — or any Postgres with pgvector; R-31 escape hatch) ---
# Supabase: Settings → Database → Connection string (use the pooled "transaction" string on Vercel)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pairgora

# --- Public site origin (canonical / og:url / sitemap build off this) ---
NEXT_PUBLIC_APP_URL=https://pairgora.com

# --- Supabase (Realtime client + server) ---
NEXT_PUBLIC_SUPABASE_URL=
# Supabase 2025 key system (preferred). Legacy names still read as fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy fallback (only set if not using the new keys above):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- LLM runtime (direct SDK, thin abstraction — § 12.1) ---
# Embeddings: text-embedding-3-small / 1536-dim (§ 15 #9). Absent → deterministic local-dev embedding.
OPENAI_API_KEY=
# Agent story generation (Step 3 narrative). Absent → template narrative fallback.
ANTHROPIC_API_KEY=

# --- Email (Resend; swap-ready to SES/Postmark — § 12.7) ---
RESEND_API_KEY=

# --- Quota tuning (§ 9.2 defaults; VUCL may tune in MVP) ---
NONMEMBER_STORE_CHAIN_PER_DAY=3
NONMEMBER_STORE_INDEPENDENT_PER_DAY=2
NONMEMBER_STORE_TOTAL_PER_DAY=5
NONMEMBER_SIGNAL_PER_DAY=20
NONMEMBER_REACT_PER_DAY=20
# Public API rate (non-member): 30 req/min, burst 60 (§ 15 #10)
PUBLIC_RATE_PER_MIN=30
PUBLIC_RATE_BURST=60
